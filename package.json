{
  "name": "copilot-sdk-proxy",
  "version": "4.1.1",
  "description": "Generic proxy server translating OpenAI/Anthropic/Codex API requests into GitHub Copilot SDK sessions",
  "type": "module",
  "license": "MIT",
  "author": "Suyash Srijan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theblixguy/copilot-sdk-proxy.git"
  },
  "homepage": "https://github.com/theblixguy/copilot-sdk-proxy#readme",
  "bugs": {
    "url": "https://github.com/theblixguy/copilot-sdk-proxy/issues"
  },
  "keywords": [
    "copilot",
    "github-copilot",
    "proxy",
    "openai",
    "anthropic",
    "claude",
    "codex"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "copilot-proxy": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#/*": {
      "copilot-sdk-proxy-dev": "./src/*",
      "default": "./dist/*"
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "config.json5"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx -C copilot-sdk-proxy-dev src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "oxfmt --write src/ test/",
    "fmt:check": "oxfmt --check src/ test/",
    "lint": "oxlint src/ test/",
    "typecheck": "tsc -p tsconfig.check.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@github/copilot-sdk": "0.2.1",
    "commander": "14.0.3",
    "fastify": "5.8.4",
    "json5": "2.2.3",
    "llm-schemas": "1.0.2",
    "picocolors": "1.1.1",
    "tokenx": "1.3.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "llm-mock-server": "1.0.6",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
